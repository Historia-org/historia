{
  "name": "historia",
  "version": "0.1.0",
  "private": true,
  "description": "Historia — wiki collaboratif de cartographie historique",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "setup:data": "node scripts/fetch-basemap.mjs",
    "db:up": "docker compose up -d db martin",
    "db:down": "docker compose down"
  }
}
