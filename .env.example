# Copy to .env then adjust
POSTGRES_USER=historia
POSTGRES_PASSWORD=historia_dev_change_me
POSTGRES_DB=historia
# Docker publishes the database on host port 5433 (5432 often taken by a local install)
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgres://historia:historia_dev_change_me@localhost:5433/historia
API_PORT=3001
